# TruthTrace AI - Environment Configuration

# Gemini AI (required for chat)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# MySQL Database (Aiven on Render)
# Paste the FULL Service URI from Aiven console (mysql:// is auto-converted):
# DATABASE_URL=mysql+aiomysql://avnadmin:PASSWORD@mysql-xxxxx.aivencloud.com:PORT/defaultdb
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/truthtrace
DATABASE_SSL_REQUIRED=true
# Optional: path to Aiven ca.pem if strict SSL fails
# DATABASE_SSL_CA=/etc/secrets/ca.pem

# Alternative: set these on Render instead of DATABASE_URL
# MYSQL_HOST=mysql-xxxxx.aivencloud.com
# MYSQL_PORT=12345
# MYSQL_USER=avnadmin
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=defaultdb

# Redis (optional - falls back to in-memory cache)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Web Search (optional - falls back to DuckDuckGo)
TAVILY_API_KEY=
SERPER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# App Settings
DEBUG=false
RATE_LIMIT=30/minute
