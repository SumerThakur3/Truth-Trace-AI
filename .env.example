# TruthTrace AI - Environment Configuration

# Gemini AI (required for chat)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# MySQL Database
# Local:  DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/truthtrace
# Aiven:  DATABASE_URL=mysql+aiomysql://avnadmin:password@mysql-xxx.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/truthtrace
# Set to true when using Aiven, PlanetScale, or other hosted MySQL (SSL is auto-detected for Aiven)
DATABASE_SSL_REQUIRED=false

# Redis (optional - falls back to in-memory cache)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Web Search (optional - falls back to DuckDuckGo)
TAVILY_API_KEY=
SERPER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# App Settings
DEBUG=false
RATE_LIMIT=30/minute
