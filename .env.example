# TruthTrace AI - Environment Configuration
# DO NOT put real passwords or API keys in this file on GitHub.
# Set secrets in Render (backend) and Vercel (frontend) dashboards.

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# Aiven MySQL (Render backend)
DATABASE_URL=mysql+aiomysql://avnadmin:YOUR_PASSWORD@mysql-XXXX.l.aivencloud.com:25057/defaultdb
DATABASE_SSL_REQUIRED=true

# Web search
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=

# Frontend (Vercel)
NEXT_PUBLIC_API_URL=https://your-render-backend.onrender.com

# Optional
REDIS_URL=redis://localhost:6379/0
DEBUG=false
