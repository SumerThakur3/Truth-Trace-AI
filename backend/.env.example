# TruthTrace AI - Backend environment template
# Copy to backend/.env locally. On Render, set these in Environment (not in GitHub).

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# Aiven MySQL — paste Service URI from Aiven console, use mysql+aiomysql:// prefix
DATABASE_URL=mysql+aiomysql://avnadmin:YOUR_PASSWORD@mysql-XXXX.l.aivencloud.com:25057/defaultdb
DATABASE_SSL_REQUIRED=true

REDIS_URL=redis://localhost:6379/0
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=
