# Render environment variables (set in Render Dashboard → Environment)
# Copy each line as a key/value — use YOUR real values, not these placeholders.

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

DATABASE_URL=mysql+aiomysql://avnadmin:YOUR_PASSWORD@mysql-XXXX.l.aivencloud.com:25057/defaultdb
DATABASE_SSL_REQUIRED=true

TAVILY_API_KEY=your-tavily-api-key

# Vercel (frontend only)
# NEXT_PUBLIC_API_URL=https://your-app.onrender.com
